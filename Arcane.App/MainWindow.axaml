<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Arcane.App.ViewModels"
        x:DataType="vm:MainWindowViewModel"
        x:Class="Arcane.App.MainWindow"
        Title="Arcane"
        Width="1100" Height="720"
        MinWidth="800" MinHeight="550"
        Background="#0F0F14"
        WindowStartupLocation="CenterScreen"
        ExtendClientAreaToDecorationsHint="True">

    <!--
        ContentControl is the single rendering slot.
        When CurrentViewModel changes, Avalonia resolves the matching
        DataTemplate from App.axaml and renders the correct View.
    -->
    <ContentControl Content="{Binding CurrentViewModel}" />

</Window>
