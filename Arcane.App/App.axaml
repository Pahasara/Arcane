<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Arcane.App.ViewModels"
             xmlns:vmAuth="using:Arcane.App.ViewModels.Auth"
             xmlns:views="using:Arcane.App.Views"
             xmlns:viewsAuth="using:Arcane.App.Views.Auth"
             xmlns:viewsShell="using:Arcane.App.Views.Shell"
             x:Class="Arcane.App.App"
             RequestedThemeVariant="Dark">

    <Application.Styles>
        <FluentTheme />
    </Application.Styles>

    <!--
        DataTemplates: ViewModel type → View type.
        Avalonia resolves these automatically when ContentControl.Content changes.
        Add a new entry here every time you add a new View/ViewModel pair.
    -->
    <Application.DataTemplates>

        <DataTemplate DataType="{x:Type vmAuth:SetupViewModel}">
            <viewsAuth:SetupView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type vmAuth:UnlockViewModel}">
            <viewsAuth:UnlockView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:MainShellViewModel}">
            <viewsShell:MainShellView />
        </DataTemplate>

    </Application.DataTemplates>

</Application>
